@inproceedings{wu2021datadrivenprediction,
author = {\hl{\textbf{M Wu}} and Arshad, MH and Saxena, KK and Qian, J and Reynaerts, D},
booktitle = {Proceedings of 17th International Symposium on Electrochemical Machining Technology (INSECT 2021)},
month = {Nov},
organization = {Leuven, Belgium (hosted virtually due to Covid-19)},
pages = {231--240},
publisher = {KU Leuven - Departement Werktuigkunde},
title = {Data-driven framework of ECM: A machine learning model for profile prediction},
year = {2021},
abstract = {Electrochemical machining (ECM) with pulsed power supply can decrease the stray current corrosion, and thus, provides better surface quality as well as machining accuracy. However, the non-linear nature of electrochemical reactions makes it challenging to predict the final profile of the machined feature through
the typical multi-physics based finite element (FEM) model. It is difficult to simulate the ECM process across wide range of processing parameters in the state-of-the-art commercial FE softwares due to several issues related to timestepping, convergence, excessive mesh distortion during moving mesh, model insensitivity to small change in parameters etc. In this article, we present a
framework of data-driven ECM model, which is based on the supervised machine learning approach, for predicting the final profile of the machined feature in ECM process. After training this data-driven ECM model with different levels of pulsed peak voltage and electrolyte flow rate, predictions and experimental validations are conducted even outside the parameter window to demonstrate the performance of generalization and applicability to a wide range of machining parameters of our data-driven ECM model.},
startyear = {2021},
startmonth = {Nov},
startday = {25},
finishyear = {2021},
finishmonth = {Nov},
finishday = {26},
isbn = {978-9-08289-313-7},
language = {English},
conference = {17th International Symposium on Electrochemical Machining Technology (INSECT 2021)},
day = {25},
publicationstatus = {published},
}

@article{wu2021fabricationmachining,
address = {https://www.sciencedirect.com/science/article/pii/S221282712031009X},
author = {\hl{\textbf{M Wu}} and Guo, Z and Qian, J and Reynaerts, D},
journal = {Procedia CIRP},
month = {Jan},
organization = {Zurich},
pages = {827--832},
publisher = {Elsevier B.V.},
title = {Fabrication of Surface Micro Letters by Electrolyte Jet Mask Machining},
url = {https://www.sciencedirect.com/journal/procedia-cirp/vol/95/suppl/C},
volume = {95},
year = {2021},
abstract = {This paper presents an experimental investigation employing lithography in Jet-ECM, namely mask electrolyte jet machining (MEJM). MEJM is a non-contact machining process which takes action to avoid manufacturing and assembling of tools (jet nozzles) in micro scale, and combines lithography with high resolution and Jet-ECM with great flexibility. The presented work investigates the effect of applied voltage and nozzle travel speed in a morphological study to test the feasibility of this hybrid process and to explore a method for complex manufacturing of surfaces features. As a case study, micro letters are produced. The process is characterized in terms of geometrical size, similarity ratio, and cumulative shape deviation. To evaluate the shaping accuracy, descriptive statistical analysis and box plot methods are employed. The results suggest MEJM could be a promising technology for batch manufacturing of micro surface structures.},
doi = {10.1016/j.procir.2020.02.261},
startyear = {2021},
startmonth = {Jan},
startday = {18},
finishyear = {2021},
finishmonth = {Jan},
finishday = {20},
issn = {2212-8271},
conference = {ISEM 2020},
day = {18},
publicationstatus = {published},
}

@inproceedings{saxena2020multiphysicsmicromachining,
author = {Saxena, KK and \hl{\textbf{M Wu}} and Chen, X and Qian, J and Reynaerts, D},
booktitle = {Proceedings of 16th International Symposium on Electrochemical Machining Technology (INSECT) 2020},
month = {Nov},
organization = {Fraunhofer IWU, Chemnitz, Germany (held virtually)},
pages = {95--104},
publisher = {VERLAG WISSENSCHAFTLICHE SKRIPTEN},
title = {Multiphysics simulation enabled ‘virtual sensing’ approach for monitoring the parameters in the interelectrode gap during tool-based hybrid laser-electrochemical micromachining},
url = {http://www.verlag-wiss-scripten.de/},
volume = {2020},
year = {2020},
abstract = {This paper presents a tool-based hybrid laser-electrochemical micromachining process that involves the simultaneous and coaxial application of electrochemical and laser process energies in the same machining zone. In this process, the tool serves both as a multimode waveguide for the laser as well as an ECM tool with sufficient conductive area. The process mechanism involves several multiphysics phenomena occurring in the interelectrode gap (IEG). The IEG is of the order of 20-50 μm. The technological limitations of putting sensors in this small IEG limits monitoring of physical quantities (such as temperature, hydrogen and oxygen gas volume fraction, electrolyte conductivity, current density on the workpiece surface) during the process. This work proposes a ‘virtual sensing’ approach showing that these physical quantities can be effectively estimated by multiphysics simulations. The evolution of the aforementioned parameters in the IEG is monitored and supported by funda-mental explanations. This research is a first step towards making ECM-based processes deterministic and minimizing experimental efforts by development of process digital twins and virtual process-monitoring.},
startyear = {2020},
startmonth = {Nov},
startday = {24},
finishyear = {2020},
finishmonth = {Nov},
finishday = {25},
isbn = {978-3-95735-125-8},
conference = {16th International Symposium on Electrochemical Machining Technology (INSECT) 2020},
day = {24},
publicationstatus = {published},
}

@article{liuelectrochemicalbronzediamond,
author = {Liu, J and Huang, Q and \hl{\textbf{M Wu}} and Zou, Z and Lin, Z and Guo, Z and He, J and Chen, X},
journal = {Science And Engineering Of Composite Materials},
month = {Nov},
number = {1},
pages = {346--358},
publisher = {De Gruyter},
title = {Electrochemical Discharge Grinding of Metal Matrix Composites Using Shaped Abrasive Tools Formed by Sintered Bronze/diamond},
volume = {27},
year = {2020},
abstract = {Electrochemical discharge machining (ECDM) is a well-known process for machining of particulate reinforced metal matrix composites (MMCs). However, ECDM process suffers several drawbacks such as the lower material removal rate (MRR), high risks of tool wear rate (TWR) and relatively poor surface quality, etc. This study proposes a kind of electrochemical discharge grinding machining (ECDGM) method which employs a special shaped tool electrode. During the process, not only the can the hybrid action of electrochemical dissolution, spark erosion, and abrasive grinding improve the performance of machining MMCs, but also the special shaped of the tool electrode can be used to discharge the machined debris. And thus a higher machining efficiency and lower TWR can be obtained. The performance of developed process was conducted on machining of SiC particulate reinforced aluminum workpiece. The role of peak curre+nt, pulse duration, duty cycle, rotary speed and abrasive grit size has been investigated on MMR and TWR using the nonabrasive round electrode, abrasive round electrode, and abrasive shaped electrode respectively. The experimental results showed that using the shaped abrasive electrode for machining MMCs can achieve a higher MRR and lower TWR, as compared to the non-abrasive round electrode, abrasive round electrode. Besides, the orthogonal method was employed to analyze the relative importance of the machining parameters on MRR and TWR, it has been observed that MRR is affected by the processing parameters following the order of rotary speed \&gt; peak current \&gt; duty cycle \&gt; pulse duration, and TWR is following the order of peak current \&gt; duty cycle \&gt; pulse duration \&gt; rotary speed.},
doi = {10.1515/secm-2020-0038},
issn = {0792-1233},
day = {3},
publicationstatus = {online-published},
}

