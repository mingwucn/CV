@Article{Yao2026Noninvasiveradio,
  author   = {Yao, Zequan and Wu*, M and Qian, Jun and Reynaerts*, Dominiek},
  journal  = {Mechanical Systems and Signal Processing},
  title    = {Non-invasive radio frequency (RF)-driven in-process monitoring and control for enhancing micro-electrical discharge machining stability and efficiency},
  year     = {2026},
  issn     = {0888-3270},
  month    = apr,
  note     = {\newline \note{\textbf{中科院一区TOP IF=8.9}} \\ \enote{IF=8.9}},
  pages    = {114072},
  volume   = {249},
  abstract = {The extremely narrow inter-electrode gap and complex gap conditions in micro-electrical discharge machining (micro-EDM) cause highly stochastic and dynamic nature of discharge behaviour. Process monitoring is essential for enhancing machining stability and efficiency by detecting discharge patterns and anomalies, particularly when combined with control strategies. Traditional EDM monitoring approaches predominantly rely on electrical sensors to discriminate pulses and infer machining states, which are subsequently used as control variables through statistical metrics. However, they suffer from high instrumentation cost, process interference, and inherent inability to capture transient dynamics. To address these challenges, this paper proposes a radio frequency (RF)-driven in-process monitoring and control scheme for micro-EDM at pulse-train level due to the non-invasive nature of RF radiation. Three machining states are defined from the integral value of voltage signals within a time window, simplifying the complex state labelling task. Given the high-frequency yet information-sparse nature of these RF signals, a low-dimensional feature dataset is constructed for machining state identification. A hybrid hierarchical deep learning model is introduced and evaluated, achieving over 90\% classification accuracy under various working conditions, with average and weighted accuracies beyond 94\% and 96\%, respectively, highlighting its reliability and robustness. Based on the identified machining states, an adaptive servo control strategy is developed and applied to deep-hole drilling scenario, significantly improving the stability and efficiency. This study integrates deep learning and in-process control to establish a cost-effective and high-performance monitoring system for micro-EDM, offering a promising pathway toward intelligent micromachining. Future work will focus on the systematic engineering integration, exploring deep synergy with CNC platforms and edge computing to accelerate the smart manufacturing.},
  doi      = {10.1016/j.ymssp.2026.114072},
  keywords = {Micro-EDM, Radio frequency (RF), Process monitoring, Adaptive control, Deep learning},
  priority = {prio3},
  ranking  = {rank4},
  urldate  = {2026-02-28},
}

 
@Article{Shao2026Compositefinitetime,
  author    = {Shao, Zhongbo and Wu*, M},
  journal   = {Processes},
  title     = {Composite finite-time ADRC for flexible-joint manipulators with frequency-domain separation},
  year      = {2026},
  issn      = {2227-9717},
  month     = jan,
  abstract  = {Flexible-joint manipulators suffer from severe performance degradation due to the coupling of joint elasticity and varying loads. To address this, we propose a composite finite-time active disturbance rejection control (CFT-ADRC) strategy utilizing a frequency-domain separation architecture. A recursive least squares (RLS) algorithm identifies slow-varying load parameters, while an extended state observer (ESO) compensates for high-frequency unmodeled dynamics and external disturbances, effectively preventing loop interference. A finite-time control law guarantees rapid tracking error convergence. Comprehensive simulations confirm that this approach significantly outperforms standard ADRC and neural network-based methods (RBFNN-ASMC). Under 50\% load variations, it achieves an RMS tracking error of 2×10−3 rad and maintains robust stability during 200\% instantaneous load mutations. The strategy presents a strong theoretical framework for future hardware implementation while maintaining an optimal balance of precision, robustness, and computational simplicity.},
  copyright = {http://creativecommons.org/licenses/by/3.0/},
  doi       = {10.3390/pr14050863},
  keywords  = {flexible-joint manipulators, active disturbance rejection control, frequency-domain separation, finite-time control, adaptive identification, robust control},
  language  = {en},
  priority  = {prio1},
  publisher = {Multidisciplinary Digital Publishing Institute},
  ranking   = {rank1},
  urldate   = {2026-03-08},
}

 
@Article{Shao2026AeroThermodynamicPhysics,
  author    = {Shao\# , Zhongbo and Zhang\#, Pengcheng and Rui, Bin and Wu*, M},
  journal   = {Energies},
  title     = {An aero-thermodynamic physics-informed neural network for small-sample performance prediction of variable-speed centrifugal Chillers},
  year      = {2026},
  issn      = {1996-1073},
  month     = mar,
  number    = {6},
  volume    = {19},
  abstract  = {Accurate performance prediction of variable-speed centrifugal chillers is important for building energy optimization and the development of digital twins in HVAC systems. In practice, obtaining extensive operational data is costly, creating a prevalent “small-sample” dilemma under which conventional data-driven models are prone to overfitting with poor extrapolation capability. While recent Physics-Informed Neural Networks (PINNs) incorporate system-level thermodynamic constraints (e.g., COP definitions), they typically treat the centrifugal compressor as a thermodynamic black box, neglecting its inherent fluid dynamic characteristics; consequently, extrapolated predictions may be physically inconsistent or fall into unsafe operating regions such as compressor surge. To address this gap, this paper proposes an Aero-thermodynamic Physics-Informed Neural Network (Aero-PINN) that introduces three mechanisms into the PINN loss function: (1) dimensionless aerodynamic similarity mapping governed by affinity laws, (2) a surge boundary constraint that prevents non-physical extrapolations, and (3) an aerodynamic–electrical energy coupling validation. Experimental validation on 420 real-world variable-speed test records shows that the Aero-PINN achieves a COP RMSE of 0.04 and a COP MAPE of 0.3%, outperforming standard MLP and polynomial baselines. Moreover, 100% of the extrapolated operating points satisfy all fluid dynamic safety and energy efficiency constraints. This framework provides a reliable, physics-constrained small-sample learning approach, facilitating factory calibration and reduced-test digital modeling for chiller plants.},
  copyright = {http://creativecommons.org/licenses/by/3.0/},
  doi       = {10.3390/en19061563},
  keywords  = {physics-informed neural network, centrifugal chiller, small-sample prediction, dimensionless aerodynamic affinity laws, surge boundary constraint, aerodynamic–electrical coupling},
  language  = {en},
  publisher = {Multidisciplinary Digital Publishing Institute},
  urldate   = {2026-03-23},
}

@Comment{jabref-meta: databaseType:bibtex;}
